# ═══════════════════════════════════════════════════════════════
# Sitiazo.cl — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
# 1. Copiar este archivo como `.env.local` (en la raíz del proyecto)
# 2. Reemplazar TODOS los valores con datos reales
# 3. NUNCA commitear .env.local al repo (ya está en .gitignore)
# 4. En Vercel: Settings → Environment Variables → agregar las mismas
#
# CRÍTICO: las variables NEXT_PUBLIC_* son visibles en el client bundle.
# NO uses estas para secrets (API keys, passwords). Usá variables sin
# prefijo NEXT_PUBLIC_ para eso.
#
# ═══════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────
# 🌐 SITE
# ─────────────────────────────────────────────

# URL canónica del sitio (sin slash final)
NEXT_PUBLIC_SITE_URL=https://sitiazo.cl


# ─────────────────────────────────────────────
# 📞 CONTACTO
# ─────────────────────────────────────────────

# Número de WhatsApp Business (formato internacional sin +)
# Ejemplo: 56945446575 (NO 569 4544 6575, NO +56945446575)
NEXT_PUBLIC_WHATSAPP_NUMBER=569XXXXXXXX

# Email principal (configurado en ImprovMX o Cloudflare Email Routing)
NEXT_PUBLIC_EMAIL=hola@sitiazo.cl

# URL de Cal.com para agendamientos
NEXT_PUBLIC_CALCOM_URL=https://cal.com/diego-sitiazo/30min


# ─────────────────────────────────────────────
# 📊 ANALYTICS (opcional para v1)
# ─────────────────────────────────────────────

# Vercel Analytics (gratis con Vercel Pro, automático)
# No requiere env var, se activa con @vercel/analytics package

# Google Analytics 4 (si decidís usarlo)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Plausible (alternativa privacy-friendly)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=sitiazo.cl


# ─────────────────────────────────────────────
# 📧 EMAIL SENDING (cuando agregues newsletter o forms)
# ─────────────────────────────────────────────

# Resend (para enviar emails programáticos desde el sitio)
# NO usar NEXT_PUBLIC_ porque expondría la API key
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────
# 🔐 SECRETS (cuando los necesités)
# ─────────────────────────────────────────────

# MercadoPago (para pagos online)
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxx

# Database connection (si agregás CMS o base de datos)
# DATABASE_URL=postgresql://...
